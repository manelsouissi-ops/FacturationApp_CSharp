@page "/"
<PageTitle>Accueil - FacturationApp</PageTitle>

<div class="hero">
    <h1>🧾 Application de Facturation</h1>
    <p>Système de facturation conforme au modèle tunisien</p>
    <div class="quick-links">
        <a href="/clients" class="btn-card">👥 Clients</a>
